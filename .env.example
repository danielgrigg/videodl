# Copy to .env and adjust for your machine.

# Host directory where videos are stored. Mounted into the container at /data/videos.
# This is the one knob you change per machine when distributing the app.
VIDEO_STORAGE_PATH=/srv/data0/studio/videos

# Max simultaneous yt-dlp downloads (keeps a pasted playlist from saturating the box).
MAX_CONCURRENT=2

# Published image tag to deploy on the server (compose.prod.yaml). Defaults to
# "latest"; pin to a short SHA or vX.Y.Z for reproducible deploys.
VIDEODL_TAG=latest
